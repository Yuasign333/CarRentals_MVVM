<Application x:Class="CarRentals_MVVM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="View/ChooseRole.xaml"
             ShutdownMode="OnLastWindowClose">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════════════════════════
                 CONVERTERS
                 Global converters available to all XAML files in the project.
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Converts bool to Visibility — used for page switching in
                 BrowseCarsWindow.xaml and error panels in login XAML files.
                 Usage: Visibility="{Binding IsPageList, Converter={StaticResource BoolToVisibility}}" -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>


            <!-- ═══════════════════════════════════════════════════════════════
                 COLOR PALETTE
                 All brand and UI colors defined once here so they are
                 consistent across every window in the application.
                 Usage: Foreground="{StaticResource BrandPrimary}"
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Brand purple shades — used for buttons, accents, highlights -->
            <SolidColorBrush x:Key="BrandPrimary"  Color="#8A2BE2"/>
            <SolidColorBrush x:Key="BrandDeep"     Color="#2D0B6B"/>
            <SolidColorBrush x:Key="BrandMedium"   Color="#3D1A7A"/>
            <SolidColorBrush x:Key="BrandLight"    Color="#C9B8E8"/>
            <SolidColorBrush x:Key="BrandSoft"     Color="#D4C5F0"/>
            <SolidColorBrush x:Key="BrandPale"     Color="#E8D8FF"/>

            <!-- Surface colors — used for input fields and card backgrounds -->
            <SolidColorBrush x:Key="SurfaceInput"  Color="#F8F4FF"/>

            <!-- Text colors — establishes visual hierarchy across the app -->
            <SolidColorBrush x:Key="TextDark"       Color="#2A1B5E"/>
            <SolidColorBrush x:Key="TextMedium"     Color="#3D1A7A"/>
            <SolidColorBrush x:Key="TextMuted"      Color="#7E74A6"/>
            <SolidColorBrush x:Key="TextLight"      Color="#C9B8E8"/>
            <SolidColorBrush x:Key="TextBreadcrumb" Color="#C4B0E0"/>
            <SolidColorBrush x:Key="TextHint"       Color="#AAA"/>

            <!-- Border colors — used for input field outlines -->
            <SolidColorBrush x:Key="BorderSoft"  Color="#D0C4F0"/>
            <SolidColorBrush x:Key="BorderInput" Color="#E0D4FF"/>

            <!-- Error colors — used in login error message panels -->
            <SolidColorBrush x:Key="ColorError"       Color="#C0304A"/>
            <SolidColorBrush x:Key="ColorErrorBg"     Color="#FFF0F5"/>
            <SolidColorBrush x:Key="ColorErrorBorder" Color="#F0C0D0"/>


            <!-- ═══════════════════════════════════════════════════════════════
                 GLOBAL TEXT STYLE
                 Applied to every TextBlock in the app automatically.
                 Individual TextBlocks can override FontSize as needed.
            ═══════════════════════════════════════════════════════════════════ -->

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize"   Value="13"/>
            </Style>


            <!-- ═══════════════════════════════════════════════════════════════
                 INPUT FIELD STYLES
                 Applied to TextBox and PasswordBox inside input borders.
                 These strip the default WPF styling for a cleaner look.
                 Connected to: AdminLogin.xaml, CustomerLogin.xaml,
                 AddCarWindow.xaml, BrowseCarsWindow.xaml (booking form)
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Used on all text input fields.
                 Removes default border and background so only the
                 outer InputBorderStyle border is visible. -->
            <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
                <Setter Property="Padding"                  Value="10,0"/>
                <Setter Property="FontSize"                 Value="14"/>
                <Setter Property="FontFamily"               Value="Segoe UI"/>
                <Setter Property="Background"               Value="Transparent"/>
                <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
                <Setter Property="BorderThickness"          Value="0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Used on all password input fields.
                 Same as InputTextBoxStyle but targets PasswordBox. -->
            <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
                <Setter Property="Padding"                  Value="10,0"/>
                <Setter Property="FontSize"                 Value="14"/>
                <Setter Property="FontFamily"               Value="Segoe UI"/>
                <Setter Property="Background"               Value="Transparent"/>
                <Setter Property="Foreground"               Value="{StaticResource TextDark}"/>
                <Setter Property="BorderThickness"          Value="0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="PasswordBox">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Outer wrapper Border for all input fields.
                 Provides the rounded corner, border color, and background.
                 On hover: border turns purple and background turns white.
                 Connected to: AdminLogin.xaml, CustomerLogin.xaml,
                 AddCarWindow.xaml, BrowseCarsWindow.xaml -->
            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderSoft}"/>
                <Setter Property="Background"      Value="{StaticResource SurfaceInput}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                        <Setter Property="Background"  Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>


            <!-- ═══════════════════════════════════════════════════════════════
                 BUTTON STYLES
                 All interactive button styles used across the application.
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Primary action button — Login, Save, Confirm, Delete, etc.
                 Scales up slightly on hover and down on press for tactile feel.
                 Background is set per-button in each XAML file.
                 Connected to: All windows with action buttons. -->
            <Style x:Key="LoginButtonStyle" TargetType="Button">
                <Setter Property="Height"          Value="46"/>
                <Setter Property="FontSize"        Value="16"/>
                <Setter Property="FontWeight"      Value="Bold"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10"
                                    Background="{TemplateBinding Background}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#C8B6FF" BlurRadius="20"
                                                      ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Scale up on hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="Opacity" To="0.88" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <!-- Scale down on press for click feedback -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="0.96" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="0.96" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Back arrow button (←) used in the top bar of all windows.
                 Transparent background, scales up and adds tint on hover.
                 Connected to: All windows with a back navigation button. -->
            <Style x:Key="BackButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{StaticResource TextMedium}"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="backBorder" Background="Transparent"
                                    CornerRadius="10" Padding="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Scale up and add subtle tint on hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.15"/>
                                                <ColorAnimation Storyboard.TargetName="backBorder" Storyboard.TargetProperty="Background.Color" To="#22C9B8E8" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Hamburger menu button (☰) in the top bar of dashboard windows.
                 Scales up and adds subtle tint on hover.
                 Connected to: AdminDashboard.xaml, CustomerDashboard.xaml -->
            <Style x:Key="HamburgerButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{StaticResource TextMedium}"/>
                <Setter Property="Width"           Value="35"/>
                <Setter Property="Height"          Value="35"/>
                <Setter Property="FontSize"        Value="18"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="hamBorder" CornerRadius="8"
                                    Background="Transparent" Padding="4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Scale up and add subtle tint on hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.15"/>
                                                <ColorAnimation Storyboard.TargetName="hamBorder" Storyboard.TargetProperty="Background.Color" To="#22C9B8E8" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Invisible button wrapper for Borders that need Command bindings.
                 Used wherever a Border needs to be clickable with a Command
                 but must keep its own visual styling intact.
                 Scales up on hover and down on press.
                 Connected to: ChooseRole.xaml (role cards),
                 AdminDashboard.xaml, CustomerDashboard.xaml (cards + sidebar),
                 All stub windows (back button),
                 AddCarWindow.xaml, BrowseCarsWindow.xaml -->
            <Style x:Key="RoleCardButtonStyle" TargetType="Button">
                <Setter Property="Background"        Value="Transparent"/>
                <Setter Property="BorderThickness"   Value="0"/>
                <Setter Property="Cursor"            Value="Hand"/>
                <Setter Property="Padding"           Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <!-- ContentPresenter renders whatever Border is
                                 placed inside the Button with no extra wrapping -->
                            <ContentPresenter/>
                            <ControlTemplate.Triggers>
                                <!-- Scale up slightly on hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.18"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <!-- Scale down on press for click feedback -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="0.97" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="0.97" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


            <!-- ═══════════════════════════════════════════════════════════════
                 BORDER / CARD STYLES
                 Animation styles applied to Border elements used as cards
                 and sidebar navigation items.
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- Dashboard card hover animation — scales up and fades slightly.
                 Applied to the large feature cards in Admin and Customer dashboards.
                 Connected to: AdminDashboard.xaml, CustomerDashboard.xaml -->
            <Style x:Key="DashCardStyle" TargetType="Border">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Scale up and fade slightly on hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.18"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.18"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.92" Duration="0:0:0.18"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Sidebar nav item hover animation — slides right on hover.
                 Applied to navigation items inside the sidebar panel.
                 Connected to: AdminDashboard.xaml, CustomerDashboard.xaml -->
            <Style x:Key="SidebarItemStyle" TargetType="Border">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform X="0"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Slide right and brighten on hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)" To="6" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <!-- Slide back and dim when mouse leaves -->
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.85" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>


            <!-- ═══════════════════════════════════════════════════════════════
                 SCROLLBAR STYLE
                 Makes the scrollbar thinner across all windows.
            ═══════════════════════════════════════════════════════════════════ -->

            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="6"/>
            </Style>


            <!-- ═══════════════════════════════════════════════════════════════
                 COMBOBOX STYLES
                 Applied globally to all ComboBoxes and their items.
                 Connected to: AddCarWindow.xaml, BrowseCarsWindow.xaml
            ═══════════════════════════════════════════════════════════════════ -->

            <!-- ComboBox base style — light purple background and border -->
            <Style TargetType="ComboBox">
                <Setter Property="Background"  Value="#F8F4FF"/>
                <Setter Property="BorderBrush" Value="#D0C4F0"/>
            </Style>

            <!-- ComboBox dropdown item style — highlights purple on hover -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#2A1B5E"/>
                <Setter Property="Padding"    Value="10,5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E8D8FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>


                <!--
            ── SIDEBAR ANIMATION STYLE ─────────────────────────────────────────
            Binds to IsSidebarOpen (bool).
            When True  → animate Width from 0 → 220 (slide in).
            When False → animate Width from 220 → 0 (slide out).
            DecelerationRatio="0.8" gives a premium ease-out deceleration feel.
        -->
            <Style x:Key="AnimatedSidebarStyle" TargetType="Border">
                <Setter Property="Width" Value="0"/>
                <Setter Property="ClipToBounds" Value="True"/>
                <Style.Triggers>
                    <!-- Slide IN when sidebar is opened -->
                    <DataTrigger Binding="{Binding IsSidebarOpen}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                    Storyboard.TargetProperty="Width"
                                    From="0" To="220"
                                    Duration="0:0:0.3"
                                    DecelerationRatio="0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <!-- Slide OUT when sidebar is closed -->
                        <DataTrigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                    Storyboard.TargetProperty="Width"
                                    From="220" To="0"
                                    Duration="0:0:0.3"
                                    DecelerationRatio="0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>