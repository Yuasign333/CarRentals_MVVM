<Window x:Class="CarRentals_MVVM.View.ProcessReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ProcessReturnDesignViewModel, IsDesignTimeCreatable=True}"
        Title="Rental Rev. — Process Return"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Viewbox Stretch="UniformToFill">
            <Grid Width="1020" Height="620">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Rectangle Grid.RowSpan="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F0EBFF" Offset="0"/>
                            <GradientStop Color="#E8F0FF" Offset="0.5"/>
                            <GradientStop Color="MediumPurple" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Image Grid.RowSpan="2" Source="https://i.imgur.com/vTJAlag.jpeg"
                       Opacity="0.06" Stretch="UniformToFill"/>
                <Ellipse Grid.RowSpan="2" Width="420" Height="420" Opacity="0.13"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#C9B8E8" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Border Grid.Row="0" Panel.ZIndex="10">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="←" FontSize="16" Style="{StaticResource BackButtonStyle}"
                                    Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                            <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                       Foreground="#C9B8E8" VerticalAlignment="Center"/>
                            <TextBlock Text="  /  " FontSize="12" Foreground="#C4B0E0" VerticalAlignment="Center"/>
                            <TextBlock Text="Process Return" FontSize="15" FontWeight="Bold"
                                       Foreground="#2A1B5E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="White" CornerRadius="20"
                                Padding="12,7" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" Foreground="#3D1A7A"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,14,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="22" Background="White">
                        <Border.Effect>
                            <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" CornerRadius="22,22,0,0" Padding="20,14,20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F0EBFF" Offset="0"/>
                                        <GradientStop Color="#E8E0FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rental ID"   FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="1" Text="Car Name"    FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="2" Text="Customer"   FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="3" Text="Hours"       FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="4" Text="Total"       FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                </Grid>
                            </Border>

                            <ListView Grid.Row="1" ItemsSource="{Binding ActiveRentals}"
                                      SelectedItem="{Binding SelectedRental}"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="20,10"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#F0EBFF"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FAF7FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#F0EBFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding RentalId}"
                                                       FontSize="12" Foreground="#9E8FC0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CarName}"
                                                       FontWeight="SemiBold" FontSize="13" Foreground="#2A1B5E"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CustomerId}"
                                                       FontSize="12" Foreground="#6B5A9E"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Hours}"
                                                       FontSize="12" Foreground="#6B5A9E"/>
                                            <TextBlock Grid.Column="4" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="#8A2BE2">
                                                <Run Text="$"/>
                                                <Run Text="{Binding TotalAmount, StringFormat='{}{0:F2}'}"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="22" Background="White">
                        <Border.Effect>
                            <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                        </Border.Effect>
                        <Grid Margin="20,20,20,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="🔄  Process Return" FontSize="14"
                                           FontWeight="Bold" Foreground="#2A1B5E"/>
                                <TextBlock Text="Select a rental from the table then confirm return."
                                           FontSize="10" Foreground="#9E8FC0" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Row="2" CornerRadius="14" Padding="16,14"
                                    Background="#F8F4FF" BorderBrush="#E0D4FF" BorderThickness="1.5">
                                <StackPanel>
                                    <TextBlock Text="Selected Rental" FontSize="11"
                                               FontWeight="Bold" Foreground="#6B4FA8" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Rental ID" FontSize="11" Foreground="#7E74A6"/>
                                        <TextBlock Text="{Binding SelectedRental.RentalId, TargetNullValue='—', FallbackValue='—'}"
                                                   HorizontalAlignment="Right" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="#2A1B5E"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Car" FontSize="11" Foreground="#7E74A6"/>
                                        <TextBlock Text="{Binding SelectedRental.CarName, TargetNullValue='—', FallbackValue='—'}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"
                                                   HorizontalAlignment="Right" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="#2A1B5E"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Driver" FontSize="11" Foreground="#7E74A6"/>
                                        <TextBlock Text="{Binding SelectedRental.DriverName, TargetNullValue='—', FallbackValue='—'}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"
                                                   HorizontalAlignment="Right" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="#2A1B5E"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Hours" FontSize="11" Foreground="#7E74A6"/>
                                        <TextBlock Text="{Binding SelectedRental.Hours, TargetNullValue='—', FallbackValue='—'}"
                                                   HorizontalAlignment="Right" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="#2A1B5E"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#E0D4FF" Margin="0,8"/>
                                    <Grid>
                                        <TextBlock Text="Total Paid" FontSize="12"
                                                   FontWeight="Bold" Foreground="#8A2BE2"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="14"
                                                   FontWeight="Bold" Foreground="#8A2BE2">
                                            <Run Text="$"/>
                                            <Run Text="{Binding SelectedRental.TotalAmount,
                                                 StringFormat='{}{0:F2}', TargetNullValue='0.00', FallbackValue='0.00'}"/>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>



                            <Button Grid.Row="4" Content="✅ Confirm Return"
                                    Height="44" FontSize="13" FontWeight="Bold"
                                    Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding ReturnCommand}"
                                    Style="{StaticResource LoginButtonStyle}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4158D0" Offset="0"/>
                                        <GradientStop Color="MediumPurple" Offset="0.5"/>
                                        <GradientStop Color="Purple" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                            <StackPanel Orientation="Horizontal" Margin="0,50,0,12">
                                <TextBlock Text="Actual Hours Returned:" FontSize="13"
Foreground="{StaticResource TextDark}"
VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Border Style="{StaticResource InputBorderStyle}" Width="90">
                                    <TextBox Text="{Binding ActualHours, UpdateSourceTrigger=PropertyChanged}"
  Style="{StaticResource InputTextBoxStyle}" Height="34" TextChanged="TextBox_TextChanged" Margin="0,0,2,0"/>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Viewbox>
    </ScrollViewer>
</Window>