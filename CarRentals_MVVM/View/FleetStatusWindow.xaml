<Window x:Class="CarRentals_MVVM.View.FleetStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:FleetStatusDesignViewModel, IsDesignTimeCreatable=True}"
        Title="Rental Rev. — Fleet Status"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="620">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BACKGROUND -->
            <Rectangle Grid.RowSpan="2" Panel.ZIndex="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Grid.RowSpan="2" Panel.ZIndex="0"
                   Source="https://i.imgur.com/vTJAlag.jpeg"
                   Opacity="0.07" Stretch="UniformToFill"/>
            <Ellipse Grid.RowSpan="2" Panel.ZIndex="0"
                     Width="420" Height="420" Opacity="0.15"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16"
                                Style="{StaticResource BackButtonStyle}"
                                Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                   Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12"
                                   Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="Fleet Status" FontSize="15" FontWeight="Bold"
                                   Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" CornerRadius="20"
                            Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔐" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}"
                                       FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1" Panel.ZIndex="5" Margin="24,14,24,20">

                <!-- Fleet Table -->
                <Border CornerRadius="22" Background="White">
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="148*"/>
                            <ColumnDefinition Width="95*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table header -->
                        <Border Grid.Row="0" CornerRadius="22,22,0,0" Padding="20,16,20,14" Grid.ColumnSpan="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F0EBFF" Offset="0"/>
                                    <GradientStop Color="#FFF3F3FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text=""
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="1" Text="ID" Margin=" -35,0,0,0"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="2" Text="Name"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="3" Text="Category"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="4" Text="Fuel Type"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="4" Text="Price/hr"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Grid.ColumnSpan="2" Margin="115,0,5,0"/>
                                <TextBlock Grid.Column="6" Text="Status"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Margin="36,0,-36,0"/>

                            </Grid>
                        </Border>

                        <!-- Car rows -->
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Cars}"
                                  SelectedItem="{Binding SelectedCar}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.ColumnSpan="2">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="20,8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0EBFF"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FAF7FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Small car image -->
                                        <Border Grid.Column="0" Width="44" Height="36"
                                                CornerRadius="8" ClipToBounds="True"
                                                VerticalAlignment="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#EDE5FF" Offset="0"/>
                                                    <GradientStop Color="#D8CCFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Image Source="{Binding ImageUrl}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock Grid.Column="1" Text="{Binding CarId}"
                                                   FontSize="12" Foreground="#9E8FC0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#2A1B5E" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Category}"
                                                   FontSize="12" Foreground="#6B5A9E"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding FuelType}"
                                                   FontSize="12" Foreground="#6B5A9E"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" FontSize="12"
                                                   Foreground="#8A2BE2" FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <Run Text="$"/>
                                            <Run Text="{Binding PricePerHour, StringFormat='{}{0:F0}'}"/>

                                        </TextBlock>




                                        <!-- Status badge -->
                                        <Border Grid.Column="6" CornerRadius="8" Padding="8,3"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EDFBF0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Rented">
                                                            <Setter Property="Background" Value="#FFF9E6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                            <Setter Property="Background" Value="#FFF0F0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="10"
                                                       FontWeight="SemiBold" TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D52"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rented">
                                                                <Setter Property="Foreground" Value="#B8860B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                                <Setter Property="Foreground" Value="#C0304A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                    </Grid>
                                </DataTemplate>

                            </ListView.ItemTemplate>
                        </ListView>
                   

                    </Grid>
                </Border>
            </Grid>

        </Grid>

    </Viewbox>
</Window>