<Window x:Class="CarRentals_MVVM.View.AdminChatListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AdminChatListDesignViewModel, IsDesignTimeCreatable=True}"
        Title="Rental Rev. — Customer Chats"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="620">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BACKGROUND — copy from any window -->
            <Rectangle Grid.RowSpan="2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Grid.RowSpan="2"
                   Source="https://i.imgur.com/vTJAlag.jpeg"
                   Opacity="0.07" Stretch="UniformToFill"/>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16"
                                Style="{StaticResource BackButtonStyle}"
                                Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                   Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12"
                                   Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="Customer Chats" FontSize="15" FontWeight="Bold"
                                   Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" CornerRadius="20"
                            Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25"
                                              ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔐" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}"
                                       FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- BODY -->
            <Border Grid.Row="1" Panel.ZIndex="5"
                    Margin="24,14,24,20" CornerRadius="22" Background="White">
                <Border.Effect>
                    <DropShadowEffect Color="#C8B6FF" BlurRadius="32"
                                      ShadowDepth="0" Opacity="0.20"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" CornerRadius="22,22,0,0" Padding="24,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F0EBFF" Offset="0"/>
                                <GradientStop Color="#F3F3FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="Select a customer to open chat"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2A1B5E"/>
                    </Border>

                    <!-- Customer list -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              Background="Transparent" BorderThickness="0" >
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="20,12"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F0EBFF"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FAF7FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EDE9FE"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar circle -->
                                    <Grid Grid.Column="0" Width="44" Height="44">

                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#8A2BE2" Offset="0"/>
                                                    <GradientStop Color="#C9B8E8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="👤" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding ProfilePicturePath}" Stretch="UniformToFill" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>

                                    <!-- Name + ID -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="14,0,0,0">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="#2A1B5E"/>
                                        <TextBlock Text="{Binding CustomerId}"
                                                   FontSize="12" Foreground="#7E74A6"/>
                                    </StackPanel>

                                    <!-- Open chat -->
                                    <Button Grid.Column="1" Content="Open Chat"
                                            Command="{Binding DataContext.OpenChatCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Style="{StaticResource LoginButtonStyle}"
                                            Height="32"  Padding="14,0" FontSize="11" Grid.ColumnSpan="2" Margin="805,6,0,6">
                                        <Button.Background>
                                            <SolidColorBrush Color="MediumPurple"/>
                                        </Button.Background>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="2"
                               Text="No customer chats yet. Customers can start a chat from their dashboard."
                               FontSize="13" Foreground="#7E74A6"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,16" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Window>