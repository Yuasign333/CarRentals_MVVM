<Window x:Class="CarRentals_MVVM.View.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        Title="Rental Rev. — Chat Support"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowState="Maximized">

    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="560">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="2" Panel.ZIndex="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Grid.RowSpan="2" Panel.ZIndex="0"
                   Source="https://i.imgur.com/vTJAlag.jpeg"
                   Opacity="0.07" Stretch="UniformToFill" Margin="-14,0,-14,0"/>
            <Ellipse Grid.RowSpan="2" Panel.ZIndex="0"
                     Width="420" Height="420" Opacity="0.15"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border Grid.Row="0" Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16"
                                Style="{StaticResource BackButtonStyle}"
                                Command="{Binding  BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                   Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12"
                                   Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="Support" FontSize="15" FontWeight="Bold"
                                   Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="White" CornerRadius="20"
                            Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}"
                                       FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Panel.ZIndex="5" Width="550" Margin="0,20,0,40" 
                    Background="#FAFAFF" CornerRadius="24">
                <Border.Effect>
                    <DropShadowEffect Color="#8A2BE2" BlurRadius="35" ShadowDepth="5" Opacity="0.15"/>
                </Border.Effect>
                <Grid Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="24,24,0,0" BorderBrush="#F0EBFF" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">

                            <Grid Width="42" Height="42" Margin="0,0,14,0">
                                <Ellipse>
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8A2BE2" Offset="0"/>
                                            <GradientStop Color="#C9B8E8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Ellipse>
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding ProfilePicturePath}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}" FontSize="16" FontWeight="Bold" Foreground="#2A1B5E"/>

                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0"/>
                                    <TextBlock Foreground="#7E74A6" FontSize="12">
    
                                        <TextBlock Text="{Binding OpenChatCommand}" Foreground="#7E74A6" FontSize="12"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,15">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Border HorizontalAlignment="{Binding Alignment}"
                                                CornerRadius="16" Padding="14,10" MaxWidth="350">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="#E8F0FF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                            <Setter Property="Background" Value="#8A2BE2"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#C8B6FF" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14" LineHeight="20">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#2A1B5E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Time}" FontSize="10" FontWeight="SemiBold"
                                                           HorizontalAlignment="Right" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#9E8FC0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                                    <Setter Property="Foreground" Value="#C8B6FF"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="White" Padding="16,16" CornerRadius="0,0,24,24" BorderBrush="#F0EBFF" BorderThickness="0,1,0,0" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="22" BorderThickness="1.5"
                                    BorderBrush="#E0D4FF" Background="#F8F4FF" Padding="16,0" Margin="0,0,12,0">
                                <TextBox x:Name="MessageBox" Text="{Binding CurrentMessage, UpdateSourceTrigger=PropertyChanged}"
                                         Height="44" Background="Transparent" BorderThickness="0"
                                         Foreground="#2A1B5E" FontSize="14" VerticalContentAlignment="Center"
                                         KeyDown="MessageBox_KeyDown" Margin="0,-2,0,2"/>
                            </Border>

                            <Button Grid.Column="1" Height="44" Width="44" Cursor="Hand"
                                    Command="{Binding SendCommand}"
                                    Style="{StaticResource LoginButtonStyle}" Padding="0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8A2BE2" Offset="0"/>
                                        <GradientStop Color="#6A1FBB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock Text="➤" FontSize="18" Foreground="White" Margin="2,0,0,0"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Window>