<Window x:Class="CarRentals_MVVM.View.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rental Rev. — Forgot Password"
        Height="620" Width="1020"
        xmlns:helpers="clr-namespace:CarRentals_MVVM.ViewModels"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Viewbox Stretch="UniformToFill">
            <Grid Width="1020" Height="620">

                <Rectangle Grid.RowSpan="2" Panel.ZIndex="0">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F0EBFF" Offset="0"/>
                            <GradientStop Color="#E8F0FF" Offset="0.5"/>
                            <GradientStop Color="MediumPurple" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Image Grid.RowSpan="2" Panel.ZIndex="0"
        Source="https://i.imgur.com/vTJAlag.jpeg"
        Opacity="0.07" Stretch="UniformToFill"/>
                <Ellipse Grid.RowSpan="2" Panel.ZIndex="0"
          Width="420" Height="420" Opacity="0.15"
          HorizontalAlignment="Right" VerticalAlignment="Top"
          Margin="0,-120,-120,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#C9B8E8" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Border CornerRadius="22" Background="White"
                        Width="440" HorizontalAlignment="Center" VerticalAlignment="Center" Height="534">
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="32"
                                          ShadowDepth="0" Opacity="0.20"/>
                    </Border.Effect>

                    <StackPanel Margin="36,32">

                        <TextBlock Text="Forgot Password" FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextDark}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Enter your username to find your account."
                                   FontSize="13"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,24"/>

                        <Border Background="{StaticResource ColorErrorBg}"
                                BorderBrush="{StaticResource ColorErrorBorder}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="12,8" Margin="0,0,0,16"
                                Visibility="{Binding ErrorVisible,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource ColorError}"
                                       FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <StackPanel Visibility="{Binding IsStep1,
                                        Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Username" FontSize="13"
                                       Foreground="{StaticResource TextDark}"
                                       Margin="0,0,0,6"/>
                            <Border Margin="0,0,0,20"
                                    Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding Username,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Height="35" />
                            </Border>
                            <Button Content="Find My Account"
                                    Command="{Binding FindAccountCommand}"
                                    Style="{StaticResource LoginButtonStyle}"
                                    Height="44">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#8A2BE2" Offset="0"/>
                                        <GradientStop Color="#6A1FBB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsStep2,
                                        Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding SecurityQuestion}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextDark}"
                                       Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <Border Margin="0,0,0,16"
                                    Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding SecurityAnswer,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Height="35" />
                            </Border>
                            <TextBlock Text="New Password" FontSize="13"
                                       Foreground="{StaticResource TextDark}"
                                       Margin="0,0,0,6"/>
                            <Border Margin="0,0,0,16"
                                    Style="{StaticResource InputBorderStyle}">
                                <PasswordBox x:Name="NewPwBox" Height="34" Background="Transparent"
             BorderThickness="0" Foreground="#2A1B5E" FontSize="12" Padding=" 0,8,0,0"/>
                            </Border>
                            <TextBlock Text="Confirm Password" FontSize="13"
                                       Foreground="{StaticResource TextDark}"
                                       Margin="0,0,0,6"/>
                            <Border Margin="0,0,0,20"
                                    Style="{StaticResource InputBorderStyle}">
                                <PasswordBox x:Name="ConfirmPwBox" Height="34" Background="Transparent"
             BorderThickness="0" Foreground="#2A1B5E" FontSize="12"  Padding=" 0,8,0,0"/>
                            </Border>
                            <Button Content="Reset Password" Height="44" FontSize="13" FontWeight="Bold"
        Foreground="White" BorderThickness="0" Cursor="Hand"
        Click="ResetBtn_Click"
        Style="{StaticResource LoginButtonStyle}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#8A2BE2" Offset="0"/>
                                        <GradientStop Color="#5B1FA8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>

                        <Button Content="← Back to Login"
                                Command="{Binding BackCommand}"
                                Style="{StaticResource BackButtonStyle}"
                                Margin="0,16,0,0" HorizontalAlignment="Left"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Viewbox>
    </ScrollViewer>
</Window>