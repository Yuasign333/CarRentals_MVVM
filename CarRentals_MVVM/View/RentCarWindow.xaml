<Window x:Class="CarRentals_MVVM.View.RentCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rental Rev. — Rent a Car"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="560">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="2" Panel.ZIndex="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Grid.RowSpan="2" Panel.ZIndex="0"
                   Source="https://i.imgur.com/vTJAlag.jpeg"
                   Opacity="0.07" Stretch="UniformToFill" Margin="-14,0,-14,0"/>
            <Ellipse Grid.RowSpan="2" Panel.ZIndex="0"
                     Width="420" Height="420" Opacity="0.15"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border Grid.Row="0" Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16" Style="{StaticResource BackButtonStyle}"
                                Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                   Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12" Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="Rent a Car" FontSize="15" FontWeight="Bold"
                                   Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" CornerRadius="20"
                            Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Panel.ZIndex="5"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <Grid Margin="24,14,24,180">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="22" Background="White">
                        <Border.Effect>
                            <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" CornerRadius="22,22,0,0" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EDE5FF" Offset="0"/>
                                        <GradientStop Color="#D8CCFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Image Source="{Binding SelectedCar.ImageUrl}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Row="1" Margin="20,14,20,20">
                                <TextBlock Text="{Binding SelectedCar.Name}"
                                           FontSize="18" FontWeight="Bold" Foreground="#2A1B5E"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                                    <Border CornerRadius="8" Padding="8,3" Margin="0,0,6,0" Background="#E8F0FF">
                                        <TextBlock Text="{Binding SelectedCar.Category}"
                                                   FontSize="11" Foreground="#3D6FCC"/>
                                    </Border>
                                    <Border CornerRadius="8" Padding="8,3" Margin="0,0,6,0" Background="#F0EBFF">
                                        <TextBlock Text="{Binding SelectedCar.FuelType}"
                                                   FontSize="11" Foreground="#6B3FCC"/>
                                    </Border>
                                    <Border CornerRadius="8" Padding="8,3" Background="#EDFBF0">
                                        <TextBlock Text="Available" FontSize="11" Foreground="#2E7D52"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="Choose Color" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,10"/>
                                <ListBox ItemsSource="{Binding SelectedCar.AvailableColors}"
                                         SelectedItem="{Binding SelectedColor}"
                                         Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Grid Width="56" Height="56">
                                                            <Ellipse Width="44" Height="44">
                                                                <Ellipse.Fill>
                                                                    <SolidColorBrush Color="{Binding}"/>
                                                                </Ellipse.Fill>
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect Color="#00000040"
                                                                                      BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                                                                </Ellipse.Effect>
                                                            </Ellipse>
                                                            <Ellipse Width="54" Height="54" StrokeThickness="2.5">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Stroke" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Value="True"
                                                                                         Binding="{Binding IsSelected,
                                                                                         RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                                                                                <Setter Property="Stroke" Value="#8A2BE2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <TextBlock Text="{Binding SelectedColor}" FontSize="12"
                                           Foreground="#7E74A6" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="22" Background="White">
                        <Border.Effect>
                            <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                        </Border.Effect>
                        <Grid Margin="24,24,24,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Booking Details" FontSize="16"
                                       FontWeight="Bold" Foreground="#2A1B5E"/>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Driver Name" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,6"/>
                                <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F8F4FF"/>
                                    </Border.Background>
                                    <TextBox Text="{Binding DriverName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34" Background="Transparent" BorderThickness="0"
                                             Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="Rental Duration (hours)" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,6"/>
                                <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F8F4FF"/>
                                    </Border.Background>
                                    <TextBox Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34" Background="Transparent" BorderThickness="0"
                                             Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                                    
                                </Border>
                            </StackPanel>
                            

                            <Border Grid.Row="6" CornerRadius="14" Padding="16,14"
                                    BorderThickness="1.5" BorderBrush="#D0C4F0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F8F4FF" Offset="0"/>
                                        <GradientStop Color="#F0EBFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="💵  " FontSize="13"/>
                                        <TextBlock Text="Rental Estimate" FontSize="13"
                                                   FontWeight="Bold" Foreground="#8A2BE2"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,5">
                                        <TextBlock Text="Base Price:" Foreground="#2A1B5E" FontSize="12"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="#2A1B5E">
                                            <Run Text="$"/>
                                            <Run Text="{Binding BasePrice, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                    <Grid Margin="0,0,0,5">
                                        <TextBlock Text="Deposit:" Foreground="#2A1B5E" FontSize="12"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="#2A1B5E">
                                            <Run Text="$"/>
                                            <Run Text="{Binding Deposit, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                    <Separator Background="#D0C4F0" Margin="0,2,0,6"/>
                                    <Grid>
                                        <TextBlock Text="Total Due:" FontWeight="Bold"
                                                   FontSize="13" Foreground="#8A2BE2"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="16"
                                                   FontWeight="Bold" Foreground="#8A2BE2">
                                            <Run Text="$"/>
                                            <Run Text="{Binding TotalDue, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button Grid.Row="8" Content="✅  Confirm Booking"
                                    Height="44" FontSize="13" FontWeight="Bold"
                                    Foreground="White" BorderThickness="0" Cursor="Hand"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding ConfirmCommand}"
                                    Style="{StaticResource LoginButtonStyle}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#8A2BE2" Offset="0"/>
                                        <GradientStop Color="#6A1FBB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Viewbox>
</Window>