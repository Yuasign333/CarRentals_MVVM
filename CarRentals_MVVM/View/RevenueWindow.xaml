<Window x:Class="CarRentals_MVVM.View.RevenueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:RevenueDesignViewModel, IsDesignTimeCreatable=True}"
        Title="Rental Rev. — Revenue"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Viewbox Stretch="UniformToFill">
            <Grid Width="1020" Height="620">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Rectangle Grid.RowSpan="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F0EBFF" Offset="0"/>
                            <GradientStop Color="#E8F0FF" Offset="0.5"/>
                            <GradientStop Color="MediumPurple" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Image Grid.RowSpan="2" Source="https://i.imgur.com/vTJAlag.jpeg"
                       Opacity="0.06" Stretch="UniformToFill"/>
                <Ellipse Grid.RowSpan="2" Width="420" Height="420" Opacity="0.13"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#C9B8E8" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Border Grid.Row="0" Panel.ZIndex="10">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="←" FontSize="16" Style="{StaticResource BackButtonStyle}"
                                    Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                            <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                       Foreground="#C9B8E8" VerticalAlignment="Center"/>
                            <TextBlock Text="  /  " FontSize="12" Foreground="#C4B0E0" VerticalAlignment="Center"/>
                            <TextBlock Text="Revenue" FontSize="15" FontWeight="Bold"
                                       Foreground="#2A1B5E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="White" CornerRadius="20"
                                Padding="12,7" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" Foreground="#3D1A7A"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,14,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="18" Padding="20,16" Background="White">
                            <Border.Effect>
                                <DropShadowEffect Color="#C8B6FF" BlurRadius="24" ShadowDepth="0" Opacity="0.20"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="💰" FontSize="22"/>
                                <TextBlock Text="Total Revenue" FontSize="11" Foreground="#7E74A6" Margin="0,6,0,4"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="#8A2BE2">
                                    <Run Text="$"/>
                                    <Run Text="{Binding TotalRevenue, StringFormat='{}{0:F2}'}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" CornerRadius="18" Padding="20,16" Background="White">
                            <Border.Effect>
                                <DropShadowEffect Color="#C8B6FF" BlurRadius="24" ShadowDepth="0" Opacity="0.20"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="📋" FontSize="22"/>
                                <TextBlock Text="Total Rentals" FontSize="11" Foreground="#7E74A6" Margin="0,6,0,4"/>
                                <TextBlock Text="{Binding TotalRentals}" FontSize="20"
                                           FontWeight="Bold" Foreground="#2A1B5E"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" CornerRadius="18" Padding="20,16" Background="White">
                            <Border.Effect>
                                <DropShadowEffect Color="#C8B6FF" BlurRadius="24" ShadowDepth="0" Opacity="0.20"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🚗" FontSize="22"/>
                                <TextBlock Text="Active Rentals" FontSize="11" Foreground="#7E74A6" Margin="0,6,0,4"/>
                                <TextBlock Text="{Binding ActiveRentals}" FontSize="20"
                                           FontWeight="Bold" Foreground="#2E7D52"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" CornerRadius="18" Padding="20,16" Background="White">
                            <Border.Effect>
                                <DropShadowEffect Color="#C8B6FF" BlurRadius="24" ShadowDepth="0" Opacity="0.20"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="📊" FontSize="22"/>
                                <TextBlock Text="Avg Per Rental" FontSize="11" Foreground="#7E74A6" Margin="0,6,0,4"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="#2A1B5E">
                                    <Run Text="$"/>
                                    <Run Text="{Binding AvgPerRental, StringFormat='{}{0:F2}'}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" CornerRadius="22" Background="White">
                        <Border.Effect>
                            <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="20,16,20,0">
                                <TextBlock Text="All Rental Transactions" FontSize="14"
                                           FontWeight="Bold" Foreground="#2A1B5E" VerticalAlignment="Center"/>
                                <Button Content="📄 Export Report"
                                        HorizontalAlignment="Right" Height="34" Padding="16,0"
                                        FontSize="12" FontWeight="Bold" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Command="{Binding ExportReportCommand}"
                                        Style="{StaticResource LoginButtonStyle}" Margin="0,-8,0,8" Width="116">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFA4A4DE" Offset="0"/>
                                            <GradientStop Color="#6A1FBB" Offset="0.7"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </Grid>

                            <Border Grid.Row="1" Padding="20,12,20,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F0EBFF" Offset="0"/>
                                        <GradientStop Color="#E8E0FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rental ID"   FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="1" Text="Car Name"    FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="1" Text="Customer"    FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Grid.ColumnSpan="2" Margin="376,0,16,0"/>
                                    <TextBlock Grid.Column="2" Text="Hours"       FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Grid.ColumnSpan="2" Margin="67,0,23,0"/>
                                    <TextBlock Grid.Column="3" Text="Date"        FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Grid.ColumnSpan="2" Margin="75,0,5,0"/>
                                    <TextBlock Grid.Column="5" Text="Total"       FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                    <TextBlock Grid.Column="6" Text="Status"      FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                </Grid>
                            </Border>

                            <ListView Grid.Row="2" ItemsSource="{Binding AllRentals}"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="20,9"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#F0EBFF"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FAF7FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding RentalId}"
                                                       FontSize="12" Foreground="#9E8FC0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CarName}"
                                                       FontWeight="SemiBold" FontSize="12" Foreground="#2A1B5E" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CustomerId}"
                                                       FontSize="12" Foreground="#6B5A9E"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Hours}"
                                                       FontSize="12" Foreground="#6B5A9E"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding RentalDate, StringFormat='{}{0:MM/dd/yy}'}"
                                                       FontSize="12" Foreground="#6B5A9E"/>
                                            <TextBlock Grid.Column="5" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="#8A2BE2">
                                                <Run Text="$"/>
                                                <Run Text="{Binding TotalAmount, StringFormat='{}{0:F2}'}"/>
                                            </TextBlock>
                                            <Border Grid.Column="6" CornerRadius="8" Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#EDFBF0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Returned">
                                                                <Setter Property="Background" Value="#F0EBFF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#2E7D52"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Returned">
                                                                    <Setter Property="Foreground" Value="#6B3FCC"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Viewbox>

    </ScrollViewer>
</Window>