<Window x:Class="CarRentals_MVVM.View.AddCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AddCarDesignViewModel, IsDesignTimeCreatable=True}"
        Title="Rental Rev. — Add Car"
        Height="620" Width="1020"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">


    <Viewbox Stretch="UniformToFill" >
        <Grid Width="1020" Height="620">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BACKGROUND -->
            <Rectangle Grid.RowSpan="2" Panel.ZIndex="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Grid.RowSpan="2" Panel.ZIndex="0"
                   Source="https://i.imgur.com/vTJAlag.jpeg"
                   Opacity="0.06" Stretch="UniformToFill"/>
            <Ellipse Grid.RowSpan="2" Panel.ZIndex="0"
                     Width="420" Height="420" Opacity="0.13"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16"
                                Style="{StaticResource BackButtonStyle}"
                                Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                   Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12"
                                   Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add/Delete Car" FontSize="15" FontWeight="Bold"
                                   Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" CornerRadius="20"
                            Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔐" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}"
                                       FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
         <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                <!-- BODY -->
            <Grid Grid.Row="1" Panel.ZIndex="5" Margin="24,14,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Car List -->
                <Border Grid.Column="0" CornerRadius="22" Background="White">
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table header -->
                        <Border Grid.Row="0" CornerRadius="22,22,0,0" Padding="20,16,20,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F0EBFF" Offset="0"/>
                                    <GradientStop Color="#FFF3F3FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ID"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="1" Text="Name"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="2" Text="Category"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="2" Text="Price/hr"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Grid.ColumnSpan="2" Margin="75,0,5,0"/>
                                <TextBlock Grid.Column="4" Text="Status"
                                           FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Margin="27,0,-27,0"/>

                                <TextBlock Grid.Column="3" Text="Speed"
             FontSize="11" FontWeight="Bold" Foreground="#6B4FA8" Grid.ColumnSpan="2" Margin="52,0,28,0"/>
                            </Grid>
                        </Border>

                        <!-- Car rows -->
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding CarList}"
                                  SelectedItem="{Binding SelectedCar}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="20,10"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0EBFF"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FAF7FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#F0EBFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CarId}"
                                                   FontSize="12" Foreground="#9E8FC0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#2A1B5E"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Category}"
                                                   FontSize="12" Foreground="#6B5A9E"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" FontSize="12" Foreground="#8A2BE2"
                                                   FontWeight="SemiBold" Grid.ColumnSpan="2" Margin="70,0,10,0">
                                            <Run Text="$"/>
                                            <Run Text="{Binding PricePerHour, StringFormat='{}{0:F0}'}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="4" Text="{Binding CarSpeed}" Margin=" -20,0,0,0"
             FontSize="12" Foreground="#6B5A9E"
             TextTrimming="CharacterEllipsis"/>

                                        <!-- Status badge -->
                                        <Border Grid.Column="4" CornerRadius="8" Padding="8,3"
        HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EDFBF0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Rented">
                                                            <Setter Property="Background" Value="#FFF9E6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                            <Setter Property="Background" Value="#FFF0F0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold"
               TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D52"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rented">
                                                                <Setter Property="Foreground" Value="#B8860B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                                <Setter Property="Foreground" Value="#C0304A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>


                <!-- RIGHT: Add Car Form -->
                <Border Grid.Column="2" CornerRadius="22" Background="White" Grid.ColumnSpan="2">
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                    </Border.Effect>

                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="Car ID (Auto-Generated)" FontSize="11" FontWeight="SemiBold"
                       Foreground="#2A1B5E" Margin="0,0,0,5"/>
                            <Border CornerRadius="11" BorderThickness="1.5"
                    BorderBrush="#E0D4FF" Padding="12,0" Height="34">
                                <Border.Background>
                                    <SolidColorBrush Color="#F0ECFF"/>
                                </Border.Background>
                                <TextBlock Text="{Binding NextCarId}"
                           Foreground="#8A2BE2" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" TextAlignment="Left"/>
                            </Border>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                            <StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Car Name" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#F8F4FF"/>
                                        </Border.Background>
                                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" Padding="0" Background="Transparent"
                                 BorderThickness="0" Foreground="#2A1B5E" FontSize="12"
                                 VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Category" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding NewCategory}" SelectedValuePath="Content"
                              Height="32" Background="Transparent" BorderThickness="0" FontSize="12">
                                        <ComboBoxItem Content="Sedan"/>
                                        <ComboBoxItem Content="SUV"/>
                                        <ComboBoxItem Content="Van"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Fuel Type" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding NewFuelType}" SelectedValuePath="Content"
                              Height="32" Background="Transparent" BorderThickness="0" FontSize="12">
                                        <ComboBoxItem Content="Standard Engine"/>
                                        <ComboBoxItem Content="EV"/>
                                        <ComboBoxItem Content="Hybrid Engine"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Price Per Hour ($)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#F8F4FF"/>
                                        </Border.Background>
                                        <TextBox Text="{Binding NewPricePerHour, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" Padding="0" Background="Transparent"
                                 BorderThickness="0" Foreground="#2A1B5E" FontSize="12"
                                 VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding NewStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
          SelectedValuePath="Content"
          Height="32" 
          Background="Transparent" 
          BorderThickness="0" 
          FontSize="12">
                                        <ComboBoxItem Content="Available"/>
                                        <ComboBoxItem Content="Rented"/>
                                        <ComboBoxItem Content="Maintenance"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Image URL" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#F8F4FF"/>
                                        </Border.Background>
                                        <TextBox Text="{Binding NewImageUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" Padding="0" Background="Transparent"
                                 BorderThickness="0" Foreground="#2A1B5E" FontSize="12"
                                 VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Available Colors (e.g., White, Gray)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                    <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#F8F4FF"/>
                                        </Border.Background>
                                        <TextBox Text="{Binding NewAvailableColors, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" Padding="0" Background="Transparent"
                                 BorderThickness="0" Foreground="#2A1B5E" FontSize="12"
                                 VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <Grid Margin="0,0,0,50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="Save" Height="40" FontSize="12" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding SaveCommand}" Style="{StaticResource LoginButtonStyle}">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#8A2BE2" Offset="0"/>
                                                <GradientStop Color="#6A1FBB" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                    </Button>

                                    <Button Grid.Column="2" Content="Delete" Height="40" FontSize="12" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding DeleteCommand}" Style="{StaticResource LoginButtonStyle}">
                                        <Button.Background>
                                            <SolidColorBrush Color="#C0304A"/>
                                        </Button.Background>
                                    </Button>

                                    <Button Grid.Column="4" Content="Update" Height="40" FontSize="12" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding UpdateCommand}" Style="{StaticResource LoginButtonStyle}">
                                        <Button.Background>
                                            <SolidColorBrush Color="#FFA4A4DE"/>
                                        </Button.Background>
                                    </Button>

                                    <Button Grid.Column="6" Content="Clr" Height="40" FontSize="12" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ClearCommand}" Style="{StaticResource LoginButtonStyle}">
                                        <Button.Background>
                                            <SolidColorBrush Color="#6B6B6B"/>
                                        </Button.Background>
                                    </Button>
                                </Grid>

                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </Border>
            </Grid>
             </ScrollViewer>
        </Grid>
    </Viewbox>
</Window>