<Window x:Class="CarRentals_MVVM.View.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rental Rev. — Sign Up"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="620">

            <!-- BACKGROUND -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Source="https://i.imgur.com/vTJAlag.jpeg" Opacity="0.07" Stretch="UniformToFill"/>
            <Ellipse Width="420" Height="420" Opacity="0.15"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Back button — always on top -->
            <Button Content="🡸" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="16,16,0,0" Command="{Binding BackCommand}"
                    Style="{StaticResource BackButtonStyle}"
                    FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand"/>

            <!-- Scrollable form -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="47,0,0,0">
                <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                        Width="520" Margin="0,50,0,40" CornerRadius="24" Padding="40,32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F0EBFF" Offset="0"/>
                            <GradientStop Color="#E8F0FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="40" ShadowDepth="0" Opacity="0.35"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Create Account" FontSize="22" FontWeight="Bold"
                                   Foreground="#2A1B5E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Register to start renting cars."
                                   FontSize="12" Foreground="#7E74A6"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border Width="90" Height="90" CornerRadius="45"
               HorizontalAlignment="Center" Margin="0,0,0,10"
               ClipToBounds="True" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                             Command="{Binding PickProfilePictureCommand}"/>
                                </Border.InputBindings>
                                <Grid>

                                    <Ellipse Stroke="Purple" StrokeThickness="2">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfilePicturePath}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Text="👤" FontSize="38"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Border VerticalAlignment="Bottom" Height="26"
                       Background="White" Margin="67,0,0,0" CornerRadius="10,10,10,10">
                                        <TextBlock Text="📷" FontSize="13"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="Tap to add photo (optional)"
                  FontSize="10" Foreground="#9E8FC0"
                  HorizontalAlignment="Center"/>
                        </StackPanel>
                        <!-- ── ERROR BANNER — only this collapses ── -->
                        <Border Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}"
                                CornerRadius="10" Background="#FFF0F0" BorderBrush="#FFBDBD"
                                BorderThickness="1" Padding="12,8" Margin="0,0,0,12">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Full Name -->
                        <TextBlock Text="Full Name" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2A1B5E" Margin="0,0,0,5"/>
                        <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF"
                                Padding="12,0" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#F8F4FF"/>
                            </Border.Background>
                            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" Background="Transparent" BorderThickness="0"
                                     Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Username -->
                        <TextBlock Text="Username" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2A1B5E" Margin="0,0,0,5"/>
                        <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF"
                                Padding="12,0" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#F8F4FF"/>
                            </Border.Background>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" Background="Transparent" BorderThickness="0"
                                     Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Password row -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Password" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F8F4FF"/>
                                    </Border.Background>
                                    <PasswordBox x:Name="PwBox" Height="34" Background="Transparent"
                                                 BorderThickness="0" Foreground="#2A1B5E" FontSize="12"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Confirm Password" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F8F4FF"/>
                                    </Border.Background>
                                    <PasswordBox x:Name="ConfirmPwBox" Height="34" Background="Transparent"
                                                 BorderThickness="0" Foreground="#2A1B5E" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Contact + License row -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Contact Number" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F8F4FF"/>
                                    </Border.Background>
                                    <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34" Background="Transparent" BorderThickness="0"
                                             Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="License Number" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2A1B5E" Margin="0,0,0,5"/>
                                <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF" Padding="12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F8F4FF"/>
                                    </Border.Background>
                                    <TextBox Text="{Binding License, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34" Background="Transparent" BorderThickness="0"
                                             Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Security Question -->
                        <TextBlock Text="Security Question" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2A1B5E" Margin="0,0,0,5"/>
                        <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF"
                                Padding="4,0" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#F8F4FF"/>
                            </Border.Background>
                            <ComboBox SelectedValue="{Binding SecurityQuestion}"
                                      SelectedValuePath="Content"
                                      Height="34" Background="Transparent" BorderThickness="0"
                                      Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="What is your pet's name?" IsSelected="True"/>
                                <ComboBoxItem Content="What is your mother's maiden name?"/>
                                <ComboBoxItem Content="What is your childhood nickname?"/>
                                <ComboBoxItem Content="What city were you born in?"/>
                            </ComboBox>
                        </Border>

                        <!-- Security Answer -->
                        <TextBlock Text="Security Answer" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2A1B5E" Margin="0,0,0,5"/>
                        <Border CornerRadius="11" BorderThickness="1.5" BorderBrush="#E0D4FF"
                                Padding="12,0" Margin="0,0,0,20">
                            <Border.Background>
                                <SolidColorBrush Color="#F8F4FF"/>
                            </Border.Background>
                            <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" Background="Transparent" BorderThickness="0"
                                     Foreground="#2A1B5E" FontSize="12" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- ── CREATE ACCOUNT BUTTON — ALWAYS VISIBLE ── -->
                        <Button Height="44" FontSize="13" FontWeight="Bold"
                                Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="RegisterBtn_Click"
                                Style="{StaticResource LoginButtonStyle}">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Create Account"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Text" Value="Creating account..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8A2BE2" Offset="0"/>
                                    <GradientStop Color="#5B1FA8" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>

                        <!-- Already have account -->
                        <Button Content="Already have an account? Log In"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#7E74A6" FontSize="11" Cursor="Hand"
                                Margin="0,8,0,0" Height="30"
                                Command="{Binding BackCommand}"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Viewbox>
</Window>