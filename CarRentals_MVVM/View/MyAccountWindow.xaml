<Window x:Class="CarRentals_MVVM.View.MyAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CarRentals_MVVM.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MyAccountDesignViewModel, IsDesignTimeCreatable=True}"
        Title="Rental Rev. — My Account"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="620">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BG -->
            <Rectangle Grid.RowSpan="2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Grid.RowSpan="2" Source="https://i.imgur.com/vTJAlag.jpeg"
                   Opacity="0.07" Stretch="UniformToFill"/>
            <Ellipse Grid.RowSpan="2" Width="420" Height="420" Opacity="0.15"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16" Style="{StaticResource BackButtonStyle}"
                                Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black"
                                   Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12" Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="My Account" FontSize="15" FontWeight="Bold"
                                   Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" CornerRadius="20"
                            Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                <!-- BODY -->
            <Grid Grid.Row="1" Margin="24,14,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Profile Card -->
                <Border Grid.Column="0" CornerRadius="22" Background="White" Margin="0,-20,0,17">
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                    </Border.Effect>
                    <StackPanel Margin="24,28,24,24">

                        <Grid Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border Width="90" Height="90" CornerRadius="45" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8A2BE2" Offset="0"/>
                                        <GradientStop Color="#C9B8E8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Ellipse Fill="White" Stroke="#C9B8E8" StrokeThickness="2" />
                                    <TextBlock Text="👤" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                    <Ellipse Stroke="Lavender" StrokeThickness="2.5">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfilePicturePath}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                </Grid>
                            </Border>

                            <Button Command="{Binding PickPictureCommand}" 
                                    Width="26" Height="26" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                                    Margin="0,0,5,5" Cursor="Hand" ToolTip="Change Photo">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="13" Background="MediumPurple" BorderBrush="White" BorderThickness="2">
                                            <TextBlock Text="📷" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Margin="0,0,0,1"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding FullName}" FontSize="16" FontWeight="Bold" 
                                   Foreground="#2A1B5E" HorizontalAlignment="Center" 
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>

                        <Grid Margin="0,0,0,16" MinHeight="24">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditingUsername}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="{Binding Username}" FontSize="13" Foreground="#7E74A6" VerticalAlignment="Center"/>
                                <Button Command="{Binding EditUsernameCommand}" Background="Transparent" BorderThickness="0" 
                                        Margin="6,0,0,0" Cursor="Hand" ToolTip="Edit Username">
                                    <TextBlock Text="✏️" FontSize="12"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditingUsername}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="110" Height="24" VerticalAlignment="Center" Padding="2"
                                         Style="{StaticResource InputTextBoxStyle}"/>

                                <Button Command="{Binding SaveUsernameCommand}" Background="Transparent" BorderThickness="0" 
                                        Margin="6,0,0,0" Cursor="Hand" ToolTip="Save Changes">
                                    <TextBlock Text="✔️" FontSize="12" Foreground="Green"/>
                                </Button>

                                <Button Command="{Binding CancelEditUsernameCommand}" Background="Transparent" BorderThickness="0" 
                                        Margin="4,0,0,0" Cursor="Hand" ToolTip="Cancel">
                                    <TextBlock Text="❌" FontSize="10" Foreground="Red"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Background="{StaticResource ColorErrorBg}" BorderBrush="{StaticResource ColorErrorBorder}"
                                BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,0,10"
                                Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ColorError}"
                                       FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                        </Border>

                        <Rectangle Height="1" Fill="#E0D4FF" Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Customer ID" FontSize="10" Foreground="#9E8FC0" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding CustomerId}" FontSize="13" FontWeight="SemiBold" Foreground="#2A1B5E"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Contact Number" FontSize="10" Foreground="#9E8FC0" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding Contact}" FontSize="13" FontWeight="SemiBold" Foreground="#2A1B5E"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="License Number" FontSize="10" Foreground="#9E8FC0" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding License}" FontSize="13" FontWeight="SemiBold" Foreground="#2A1B5E"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#E0D4FF" Margin="0,8,0,14"/>

                        <Button Content="🚗  Browse Cars" Height="38" FontSize="12"
                                FontWeight="Bold" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Command="{Binding BrowseCarsCommand}"
                                Style="{StaticResource LoginButtonStyle}">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4158D0" Offset="0"/>
                                    <GradientStop Color="MediumPurple" Offset="0.5"/>
                                    <GradientStop Color="Purple" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <!-- Delete Account button — red, at bottom of profile card -->
                        <Rectangle Height="1" Fill="#FFE0D4" Margin="0,10,0,10"/>
                        <Button Content="🗑  Delete Account" Height="32" FontSize="12"
        FontWeight="Bold" Foreground="White" BorderThickness="0"
        Cursor="Hand" Command="{Binding DeleteAccountCommand}"
        Style="{StaticResource LoginButtonStyle}" Margin="0,0,0,0">
                            <Button.Background>
                                <SolidColorBrush Color="#C0304A"/>
                            </Button.Background>
                        </Button>
                    </StackPanel>
                </Border>
                <!-- RIGHT: Rental History -->
                <Border Grid.Column="2" CornerRadius="22" Background="White" Margin="0,-20,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#C8B6FF" BlurRadius="32" ShadowDepth="0" Opacity="0.20"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📋  Rental History" FontSize="14"
                                   FontWeight="Bold" Foreground="#2A1B5E" Margin="20,16,20,0"/>

                        <!-- Header -->
                        <Border Grid.Row="1" Padding="20,10" Margin="0,10,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F0EBFF" Offset="0"/>
                                    <GradientStop Color="#E8E0FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rental ID"  FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="1" Text="Car"        FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="2" Text="Driver"     FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="3" Text="Hours"      FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="4" Text="Date"       FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                                <TextBlock Grid.Column="5" Text="Status"     FontSize="11" FontWeight="Bold" Foreground="#6B4FA8"/>
                            </Grid>
                        </Border>

                        <!-- Rows -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Rentals}" Height="436">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="20,10" BorderBrush="#F0EBFF" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding RentalId}"
                                                           FontSize="12" Foreground="#9E8FC0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CarName}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="#2A1B5E" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DriverName}"
                                                           FontSize="12" Foreground="#6B5A9E"
                                                           TextTrimming="CharacterEllipsis" Grid.ColumnSpan="2" Margin="160,-2,26,2"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Hours}"
                                                           FontSize="12" Foreground="#6B5A9E" Margin="10,2,90,0" Grid.ColumnSpan="2"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding RentalDate, StringFormat='MM/dd/yy'}"
                                                           FontSize="12" Foreground="#6B5A9E" Grid.ColumnSpan="2" Margin="67,1,13,-1"/>
                                                <Border Grid.Column="4" CornerRadius="8" Padding="8,3" HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="92,-1,0,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFF9E6"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Returned">
                                                                    <Setter Property="Background" Value="#EDFBF0"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#B8860B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Returned">
                                                                        <Setter Property="Foreground" Value="#2E7D52"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                                <!-- Empty state -->
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRentals}" Value="False">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <StackPanel HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center" Margin="0,40">
                                                                <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="No rentals yet" FontSize="15"
                                                                           FontWeight="Bold" Foreground="#2A1B5E"
                                                                           HorizontalAlignment="Center" Margin="0,10,0,4"/>
                                                                <TextBlock Text="Your rental history will appear here."
                                                                           FontSize="12" Foreground="#7E74A6"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
          </ScrollViewer>
        </Grid>
    </Viewbox>
</Window>