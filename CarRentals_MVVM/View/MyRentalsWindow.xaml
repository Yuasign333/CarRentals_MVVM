<Window x:Class="CarRentals_MVVM.View.MyRentalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rental Rev. — My Rentals"
        Height="620" Width="1020"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Viewbox Stretch="UniformToFill">
        <Grid Width="1020" Height="620">

            <!-- BG -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0EBFF" Offset="0"/>
                        <GradientStop Color="#E8F0FF" Offset="0.5"/>
                        <GradientStop Color="MediumPurple" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Image Source="https://i.imgur.com/vTJAlag.jpeg" Opacity="0.07" Stretch="UniformToFill"/>
            <Ellipse Width="420" Height="420" Opacity="0.15" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C9B8E8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- TOP BAR -->
            <Border VerticalAlignment="Top" Height="56">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" FontSize="16" Style="{StaticResource BackButtonStyle}"
                                Command="{Binding BackCommand}" Margin="0,0,10,0"/>
                        <TextBlock Text="RENTAL REV." FontSize="12" FontWeight="Black" Foreground="#C9B8E8" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  " FontSize="12" Foreground="#C4B0E0" VerticalAlignment="Center"/>
                        <TextBlock Text="My Rentals" FontSize="15" FontWeight="Bold" Foreground="#2A1B5E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="12,7" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" Foreground="#3D1A7A"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CARD -->
            <Border Margin="28,68,28,20" CornerRadius="20" Background="White">
                <Border.Effect>
                    <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.22"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Card title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="28,22,28,0">
                        <TextBlock Text="📋  " FontSize="16"/>
                        <TextBlock Text="My Rentals" FontSize="17" FontWeight="Bold" Foreground="#2A1B5E"/>
                    </StackPanel>

                    <!-- Table header -->
                    <Border Grid.Row="1" Margin="0,14,0,0" Padding="28,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8A2BE2" Offset="0"/>
                                <GradientStop Color="#6A1FBB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rental ID"  FontWeight="Bold" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="Car ID"     FontWeight="Bold" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="Driver"     FontWeight="Bold" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="Start Date" FontWeight="Bold" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="4" Text="Est. Hours" FontWeight="Bold" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="5" Text="Cost"       FontWeight="Bold" Foreground="White" FontSize="12"/>
                            <TextBlock Grid.Column="6" Text="Status"     FontWeight="Bold" Foreground="White" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Rows / Empty state -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Rentals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="28,14" BorderBrush="#F0EBFF" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding RentalId}" Foreground="#7E74A6" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CarId}" Foreground="#7E74A6" FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="{Binding DriverName}" FontWeight="SemiBold" Foreground="#2A1B5E"/>
                                            <TextBlock Grid.Column="3" Text="{Binding StartDate, StringFormat='yyyy-MM-dd'}" Foreground="#7E74A6" FontSize="12"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Hours}" Foreground="#7E74A6" FontSize="12"/>
                                            <TextBlock Grid.Column="5" Foreground="#2A1B5E" FontWeight="SemiBold">
                                                <Run Text="$"/><Run Text="{Binding TotalCost, StringFormat='{}{0:F2}'}"/>
                                            </TextBlock>
                                            <!-- Status badge -->
                                            <Border Grid.Column="6" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFF9E6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                <Setter Property="Background" Value="#E6FFF5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#B8860B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                    <Setter Property="Foreground" Value="#2E7D52"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                            <!-- Empty state -->
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRentals}" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,48">
                                                            <TextBlock Text="📋" FontSize="44" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="No rentals yet" FontSize="17" FontWeight="Bold"
                                                                       Foreground="#2A1B5E" HorizontalAlignment="Center" Margin="0,10,0,4"/>
                                                            <TextBlock Text="Your rental history will appear here."
                                                                       FontSize="13" Foreground="#7E74A6" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>

                  
                   
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Window>