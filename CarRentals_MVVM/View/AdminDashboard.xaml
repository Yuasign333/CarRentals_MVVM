<Window x:Class="CarRentals_MVVM.View.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rental Rev. — Admin Dashboard"
        Height="600" Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">



   

    <Viewbox Stretch="UniformToFill">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Style="{StaticResource AnimatedSidebarStyle}" HorizontalAlignment="Left">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF7D4FD2" Offset="0"/>
                        <GradientStop Color="#E8D8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Width="220" HorizontalAlignment="Left">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Source="https://i.imgur.com/vTJAlag.jpeg" Opacity="0.10"
               Stretch="Fill" Margin="-18,0,5,0" Grid.RowSpan="3">
                        <Image.Effect>
                            <BlurEffect Radius="18"/>
                        </Image.Effect>
                    </Image>

                    <StackPanel Grid.Row="0" Margin="0,26,0,28" HorizontalAlignment="Center">
                        <Border Width="150" Height="103" ClipToBounds="True">
                            <Image Source="https://i.imgur.com/yVApvuV.png"
                       Stretch="UniformToFill" Margin="0,-47,0,39"/>
                        </Border>
                        <TextBlock Text="RENTAL REV." FontSize="28" FontWeight="Bold"
                       Foreground="Lavender" Margin="0,-38,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="16,0">

                        <Button Style="{StaticResource RoleCardButtonStyle}" Padding="0" Margin="0,8,0,4">
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Dashboard" FontWeight="Bold" Foreground="White" Margin=" 0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding FleetCommand}" Padding="0" Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚗" Margin="0,0,8,0"/>
                                    <TextBlock Text="Fleet Status" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ReturnCommand}" Padding="0" Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄" Margin="0,0,8,0"/>
                                    <TextBlock Text="Process Return" FontWeight="Bold" Foreground="White" Margin="0,-1,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding AddCarCommand}" Padding="0" Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="➕" Margin="0,0,8,0"/>
                                    <TextBlock Text="Add Car" FontWeight="Bold" Foreground="White" Margin="0,-1,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding MaintenanceCommand}" Padding="0" Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" Margin="0,0,8,0"/>
                                    <TextBlock Text="Maintenance" FontWeight="Bold" Foreground="White" Margin="0,-1,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding RevenueCommand}" Padding="0" Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💰" Margin="0,0,8,0"/>
                                    <TextBlock Text="Revenue" FontWeight="Bold" Foreground="White" Margin="0,-1,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ChatCommand}" Padding="0" Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand" Style="{StaticResource SidebarItemStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" Margin="0,0,8,0"/>
                                    <TextBlock Text="Customer Chats" FontWeight="Bold" Foreground="White" Margin="0,-1,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="16,0,16,24">
                        <Button Command="{Binding LogoutCommand}" Padding="0" Style="{StaticResource RoleCardButtonStyle}">
                            <Border CornerRadius="14" Padding="14,12" Cursor="Hand">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#E8D8FF" Offset="0"/>
                                        <GradientStop Color="LavenderBlush" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏻" Margin="0,0,8,0"/>
                                    <TextBlock Text="Log Out" FontWeight="Bold" Foreground="{StaticResource TextMedium}"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <TextBlock Text="Made by Yuan" FontSize="10" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                </Grid>
            </Border>
            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="115*"/>
                    <RowDefinition Height="187*"/>
                </Grid.RowDefinitions>
                <Rectangle Grid.RowSpan="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F0EBFF" Offset="0"/>
                            <GradientStop Color="#E8F0FF" Offset="0.5"/>
                            <GradientStop Color="MediumPurple" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Image Source="https://i.imgur.com/vTJAlag.jpeg" Opacity="0.10"
                       Stretch="UniformToFill" Margin="0,10,1,-3" Grid.RowSpan="2"/>
                <Ellipse Width="420" Height="420" Opacity="0.18"
                         HorizontalAlignment="Right" VerticalAlignment="Top"
                         Margin="0,-120,-120,0" Grid.RowSpan="2">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#C9B8E8" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="320" Height="320" Opacity="0.12"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom"
                         Margin="-60,0,0,-60" Grid.Row="1">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#B8D4F0" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- TOP BAR -->
                <Border VerticalAlignment="Top" Height="60" BorderThickness="0">
                    <Grid Margin="28,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="☰"
                                Style="{StaticResource HamburgerButtonStyle}"
                                Command="{Binding HamburgerCommand}"
                                VerticalAlignment="Center" Margin="-10,0,10,0"/>
                        <TextBlock Text="Admin Dashboard"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextMedium}"
                                   VerticalAlignment="Top" Margin="25,18,22,0"
                                   Grid.ColumnSpan="2"/>
                        <Border Grid.Column="2" Background="White"
                                CornerRadius="20" Padding="12,7" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#C9B8E8" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UserLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMedium}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- BODY -->
                <Grid Margin="36,76,36,24" Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding WelcomeText}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextDark}"/>
                        <TextBlock Text="Manage fleet, rentals and operations."
                                   Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="2">
                        <!-- Fleet Status card -->
                        <Button Command="{Binding FleetCommand}" Padding="0" Margin="0,0,18,18">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border Width="210" Height="130" CornerRadius="20" Cursor="Hand"
                                    Style="{StaticResource DashCardStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0.01"/>
                                        <GradientStop Color="Lavender" Offset="0.4"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="🚗" FontSize="26"/>
                                        <TextBlock Text="Fleet Status"  FontSize="16" FontWeight="Bold" Margin="0,12,0,2"
                                                       Foreground="#2A1B5E"/>
                                        <TextBlock Text="View all vehicles" FontSize="12" Foreground="#5F5A87"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- Process Return card -->
                        <Button Command="{Binding ReturnCommand}" Padding="0" Margin="0,0,18,18">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border Width="210" Height="130" CornerRadius="20" Cursor="Hand"
                                    Style="{StaticResource DashCardStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0.01"/>
                                        <GradientStop Color="Lavender" Offset="0.4"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="🔄" FontSize="26"/>
                                        <TextBlock Text="Process Return" FontSize="16"     Foreground="#2A1B5E" FontWeight="Bold" Margin="0,12,0,2"/>
                                        <TextBlock Text="Complete active returns" FontSize="12" Foreground="#5F5A87"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- Add Car card -->
                        <Button Command="{Binding AddCarCommand}" Padding="0" Margin="0,0,18,18">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border Width="210" Height="130" CornerRadius="20" Cursor="Hand"
                                    Style="{StaticResource DashCardStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0.01"/>
                                        <GradientStop Color="Lavender" Offset="0.4"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="➕" FontSize="26"/>
                                        <TextBlock Text="Add/Delete Car" FontSize="16"  Foreground="#2A1B5E" FontWeight="Bold" Margin="0,12,0,2"/>
                                        <TextBlock Text="Register new vehicle and delete" FontSize="12" Foreground="#5F5A87"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- Maintenance card -->
                        <Button Command="{Binding MaintenanceCommand}" Padding="0" Margin="0,0,18,18">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border Width="210" Height="130" CornerRadius="20" Cursor="Hand"
                                    Style="{StaticResource DashCardStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0.01"/>
                                        <GradientStop Color="Lavender" Offset="0.4"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="🔧" FontSize="26"/>
                                        <TextBlock Text="Maintenance"  Foreground="#2A1B5E"  FontSize ="16" FontWeight="Bold" Margin="0,12,0,2"/>
                                        <TextBlock Text="Manage service records" FontSize="12" Foreground="#5F5A87"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </WrapPanel>


                    <Button Command="{Binding ChatCommand}"
                      Style="{StaticResource RoleCardButtonStyle}" 
                        Padding="0" 
                         Margin="226,165,476,61" 
                     Grid.Row="2"
                 BorderThickness="0"
                 Background="Transparent"
                 Cursor="Hand">

                        <Border Width="210" Height="130" CornerRadius="20" Margin =" 0,-30,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0.01"/>
                                    <GradientStop Color="Lavender" Offset="0.4"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Border.Effect>
                                <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                            </Border.Effect>

                            <Grid Margin="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="86*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Grid.ColumnSpan="2">
                                    <TextBlock Text="💬" FontSize="26"/>
                                    <TextBlock Text="Customer Chats" 
                           FontWeight="Bold" 
                           FontSize="16"
                           Foreground="#2A1B5E"
                           Margin="0,12,0,2"/>
                                    <TextBlock Text="Reply to Customers" 
                           FontSize="12" 
                           Foreground="#5F5A87"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>

                    <!-- Revenue card below Fleet Status -->
                    <Border Width="210" Height="130" CornerRadius="20"
                            Margin="0,80,702,10" Grid.Row="2">
                        <Button Command="{Binding RevenueCommand}" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Border Width="210" Height="130" CornerRadius="20" Cursor="Hand"
                                    Style="{StaticResource DashCardStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0.01"/>
                                        <GradientStop Color="Lavender" Offset="0.4"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#C8B6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="💰" FontSize="26"/>
                                        <TextBlock Text="Revenue"  FontSize="16" FontWeight="Bold" Margin="0,12,0,2" Foreground="#2A1B5E"/>
                                        <TextBlock Text="Earnings &amp; analytics" FontSize="12" Foreground="#5F5A87"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </Border>









                    <Border Width="210" Height="130" CornerRadius="20"
         Margin="0,136,702,136" Grid.Row="2">
                        <Button Command="{Binding TotalCarStatusCommand }" Padding="0" Margin="10,-65,-10,65">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>






                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
